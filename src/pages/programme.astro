---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import PbImage from '../components/PbImage.astro';
import { getAllArtistes, getSceneById } from '../../backend/backend.mjs';

// Recuperer tous les artistes depuis PocketBase
const artistes = await getAllArtistes();

// Fonction pour formater la date
function formatDate(dateStr) {
  if (!dateStr) return "";
  const date = new Date(dateStr);
  const options = { day: 'numeric', month: 'long' };
  return date.toLocaleDateString('fr-FR', options);
}

// Fonction pour formater l'heure
function formatTime(dateStr) {
  if (!dateStr) return "";
  const date = new Date(dateStr);
  return date.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
}
---

<Layout>
  <PageHeader 
    title="Programme" 
    subtitle="Decouvrez les concerts exceptionnels de cette 27eme edition" 
  />

  <section class="py-12 px-4 max-w-4xl mx-auto">
    
    {artistes.length === 0 ? (
      <p class="text-center text-grisclair">Aucun concert programme pour le moment.</p>
    ) : (
      artistes.map(async (artiste) => {
        // Recuperer la scene si elle existe
        let scene = null;
        if (artiste.scene) {
          try {
            scene = await getSceneById(artiste.scene);
          } catch (e) {
            scene = null;
          }
        }
        
        return (
          <div class="bg-white p-6 rounded shadow mb-6">
            <div class="flex flex-col md:flex-row gap-6">
              
              <!-- Image de l'artiste -->
              <div class="md:w-1/4">
                {artiste.image ? (
                  <PbImage 
                    record={artiste} 
                    filename={artiste.image} 
                    alt={artiste.nom}
                    class="w-full h-32 object-cover rounded"
                  />
                ) : (
                  <div class="w-full h-32 bg-doreclair rounded flex items-center justify-center">
                    <span class="text-orprofond text-3xl">&#9835;</span>
                  </div>
                )}
              </div>
              
              <!-- Infos du concert -->
              <div class="md:w-3/4">
                <span class="text-orprofond font-bold">
                  {formatDate(artiste.date_de_representation)}
                </span>
                
                <h2 class="text-2xl font-bold mb-2">{artiste.nom}</h2>
                
                <p class="text-grisclair mb-2">
                  {scene ? scene.nom : "Lieu a confirmer"} | {formatTime(artiste.date_de_representation)}
                </p>
                
                {artiste.genre && (
                  <p class="text-sm text-orprofond mb-2">Genre : {artiste.genre}</p>
                )}
                
                {artiste.description && (
                  <p class="mb-4 line-clamp-2">{artiste.description}</p>
                )}
                
                <div class="flex gap-4">
                  <a 
                    href={`/artistes/${artiste.id}`} 
                    class="text-orprofond hover:underline"
                  >
                    En savoir plus
                  </a>
                  <a 
                    href="#" 
                    class="bg-orprofond text-noir px-4 py-2 rounded hover:bg-doreclair inline-block"
                  >
                    Reserver
                  </a>
                </div>
              </div>
              
            </div>
          </div>
        );
      })
    )}

  </section>
</Layout>
