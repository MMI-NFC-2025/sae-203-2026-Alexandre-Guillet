---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import ArtisteCard from '../components/ArtisteCard.astro';
import { getAllArtistes, getAllScenes } from '../../backend/backend.mjs';

const artistes = await getAllArtistes();
const scenes = await getAllScenes();
const genres = [...new Set(artistes.map((a: any) => a.specialite).filter(Boolean))].sort();
---

<Layout>
  <PageHeader title="Programme" subtitle="Centre musical du festival" />
  <section class="py-12 px-4 max-w-6xl mx-auto">
      <div class="bg-doreclair p-6 rounded">
        <h3 class="font-bold mb-4">Par scène ({scenes.length})</h3>
        <div class="flex flex-wrap gap-2">
          {scenes.map((scene: any) => (
            <button 
              class="filter-btn bg-noir text-ivoir px-3 py-1 rounded text-sm hover:bg-orprofond"
              data-filter="scene"
              data-value={scene.id}
              data-name={scene.nom}
            >
              {scene.nom}
            </button>
          ))}
        </div>
      </div>

      <div class="bg-doreclair p-6 rounded flex items-end">
        <button 
          onclick="location.reload()"
          class="w-full bg-orprofond text-noir px-4 py-2 rounded font-bold hover:bg-doreclair"
        >
          Réafficher tous
        </button>
      </div>
    </div>

    <div id="artistes-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {artistes.map((artiste: any) => (
        <div class="artiste-item" data-genre={artiste.specialite} data-scene={artiste.scene}>
          <ArtisteCard artiste={artiste} />
        </div>
      ))}
    </div>
  </section>

  <script>
    // @ts-nocheck
    const buttons = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.artiste-item');
    let activeFilter = { genre: null, scene: null };

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        const value = btn.dataset.value;
        
        if (activeFilter[filter] === value) {
          activeFilter[filter] = null;
          btn.classList.remove('bg-orprofond');
          btn.classList.add('bg-noir');
        } else {
          activeFilter[filter] = value;
          buttons.forEach((b) => {
            if (b.dataset.filter === filter && b !== btn) {
              b.classList.remove('bg-orprofond');
              b.classList.add('bg-noir');
            }
          });
          btn.classList.add('bg-orprofond');
          btn.classList.remove('bg-noir');
        }
        
        items.forEach((item) => {
          const showGenre = !activeFilter.genre || item.dataset.genre === activeFilter.genre;
          const showScene = !activeFilter.scene || item.dataset.scene === activeFilter.scene;
          item.style.display = (showGenre && showScene) ? '' : 'none';
        });
      });
    });
  </script>
</Layout>
