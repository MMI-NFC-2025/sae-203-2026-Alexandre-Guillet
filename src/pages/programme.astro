---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Titre de la page -->
  <section class="bg-noir text-ivoir text-center py-16 px-4">
    <h1 class="text-4xl font-bold mb-4">Programme</h1>
    <p class="text-xl">Decouvrez les concerts exceptionnels de cette 27eme edition</p>
  </section>

  <!-- Liste des concerts -->
  <section class="py-12 px-4 max-w-4xl mx-auto">
    
    <!-- Concert 1 -->
    <div class="bg-white p-6 rounded shadow mb-6">
      <span class="text-orprofond font-bold">15 Juin</span>
      <h2 class="text-2xl font-bold mb-2">Concert d'ouverture - Symphonie n°9 de Beethoven</h2>
      <p class="text-grisclair mb-2">Opera National de Paris - Grande Salle | 20h00</p>
      <p class="mb-4">Une interpretation magistrale de l'Hymne a la joie pour inaugurer le festival</p>
      <p class="text-sm mb-4">Direction : Gustavo Dudamel | Orchestre : Orchestre Philharmonique de Paris</p>
      <a href="#" class="bg-orprofond text-noir px-4 py-2 rounded hover:bg-doreclair">Reserver</a>
    </div>

    <!-- Concert 2 -->
    <div class="bg-white p-6 rounded shadow mb-6">
      <span class="text-orprofond font-bold">16 Juin</span>
      <h2 class="text-2xl font-bold mb-2">Les Quatre Saisons de Vivaldi</h2>
      <p class="text-grisclair mb-2">Theatre des Champs-Elysees | 20h00</p>
      <p class="mb-4">Une celebration baroque avec l'un des plus grands violonistes de notre temps</p>
      <p class="text-sm mb-4">Violon solo : Anne-Sophie Mutter | Ensemble : Ensemble Baroque de Paris</p>
      <a href="#" class="bg-orprofond text-noir px-4 py-2 rounded hover:bg-doreclair">Reserver</a>
    </div>

    <!-- Concert 3 -->
    <div class="bg-white p-6 rounded shadow mb-6">
      <span class="text-orprofond font-bold">17 Juin</span>
      <h2 class="text-2xl font-bold mb-2">Concerto pour piano n°2 de Rachmaninov</h2>
      <p class="text-grisclair mb-2">Salle Pleyel | 20h00</p>
      <p class="mb-4">Virtuosite et emotion dans l'une des oeuvres les plus appreciees du repertoire</p>
      <p class="text-sm mb-4">Piano : Lang Lang | Direction : Simon Rattle</p>
      <a href="#" class="bg-orprofond text-noir px-4 py-2 rounded hover:bg-doreclair">Reserver</a>
    </div>

    <!-- Concert 4 -->
    <div class="bg-white p-6 rounded shadow mb-6">
      <span class="text-orprofond font-bold">18 Juin</span>
      <h2 class="text-2xl font-bold mb-2">Le Sacre du Printemps - Stravinsky</h2>
      <p class="text-grisclair mb-2">Opera National de Paris - Grande Salle | 20h00</p>
      <p class="mb-4">Une oeuvre revolutionnaire qui a marque l'histoire de la musique</p>
      <p class="text-sm mb-4">Direction : Esa-Pekka Salonen | Orchestre : Orchestre de Paris</p>
      <a href="#" class="bg-orprofond text-noir px-4 py-2 rounded hover:bg-doreclair">Reserver</a>
    </div>

    <!-- Concert 5 -->
    <div class="bg-white p-6 rounded shadow mb-6">
      <span class="text-orprofond font-bold">19 Juin</span>
      <h2 class="text-2xl font-bold mb-2">Requiem de Mozart</h2>
      <p class="text-grisclair mb-2">Basilique Sainte-Clotilde | 20h00</p>
      <p class="mb-4">Une interpretation intimiste dans un cadre exceptionnel</p>
      <p class="text-sm mb-4">Direction : Philippe Herreweghe | Choeur : Collegium Vocale Gent</p>
      <a href="#" class="bg-orprofond text-noir px-4 py-2 rounded hover:bg-doreclair">Reserver</a>
    </div>

    <!-- Concert 6 -->
    <div class="bg-white p-6 rounded shadow mb-6">
      <span class="text-orprofond font-bold">20 Juin</span>
      <h2 class="text-2xl font-bold mb-2">Symphonie n°5 de Mahler</h2>
      <p class="text-grisclair mb-2">Theatre des Champs-Elysees | 20h00</p>
      <p class="mb-4">Une oeuvre monumentale portee par l'un des plus grands orchestres du monde</p>
      <p class="text-sm mb-4">Direction : Valery Gergiev | Orchestre : Mariinsky Orchestra</p>
      <a href="#" class="bg-orprofond text-noir px-4 py-2 rounded hover:bg-doreclair">Reserver</a>
    </div>

    <!-- Concert 7 -->
    <div class="bg-white p-6 rounded shadow mb-6">
      <span class="text-orprofond font-bold">21 Juin</span>
      <h2 class="text-2xl font-bold mb-2">Concerto pour violon de Tchaikovski</h2>
      <p class="text-grisclair mb-2">Salle Pleyel | 20h00</p>
      <p class="mb-4">Passion russe et virtuosite technique dans un concerto legendaire</p>
      <p class="text-sm mb-4">Violon : Hilary Hahn | Direction : Yannick Nezet-Seguin</p>
      <a href="#" class="bg-orprofond text-noir px-4 py-2 rounded hover:bg-doreclair">Reserver</a>
    </div>

    <!-- Concert 8 -->
    <div class="bg-white p-6 rounded shadow mb-6">
      <span class="text-orprofond font-bold">22 Juin</span>
      <h2 class="text-2xl font-bold mb-2">Concert de cloture - Symphonie n°7 de Beethoven</h2>
      <p class="text-grisclair mb-2">Opera National de Paris - Grande Salle | 20h00</p>
      <p class="mb-4">Une conclusion triomphale avec l'une des symphonies les plus exaltantes</p>
      <p class="text-sm mb-4">Direction : Daniel Barenboim | Orchestre : West-Eastern Divan Orchestra</p>
      <a href="#" class="bg-orprofond text-noir px-4 py-2 rounded hover:bg-doreclair">Reserver</a>
    </div>

  </section>
</Layout>
