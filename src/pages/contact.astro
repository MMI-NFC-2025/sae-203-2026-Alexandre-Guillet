---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import * as backend from "../../backend/backend.mjs";
let message = "";
if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    const response = await (backend as any).addMessage(formData);
    message = response.message;
}
---
<Layout>
  <PageHeader
    title="Contact"
    subtitle="Envoyez-nous un message"
  />

  <section class="py-12 px-4 max-w-lg mx-auto">
    <div class="bg-ivoir p-8 rounded shadow">
      <form action="/contact" method="POST" class="space-y-6">
        <div>
          <label for="nom" class="block font-bold mb-2">Nom complet</label>
          <input
            type="text"
            id="nom"
            name="Nom"
            required
            class="w-full border rounded px-3 py-2 bg-white"
            placeholder="Jean-Michel"
          />
        </div>

        <div>
          <label for="email" class="block font-bold mb-2">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full border rounded px-3 py-2 bg-white"
            placeholder="ex: jean.michel@example.com"
          />
        </div>

        <div>
          <label for="message" class="block font-bold mb-2">Message</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="w-full border rounded px-3 py-2 bg-white"
            placeholder="Votre message"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-orprofond text-noir px-6 py-2 rounded font-bold hover:bg-doreclair"
        >
          Envoyer le message
        </button>

        {message && <p class="mt-4 text-green-600">{message}</p>}
      </form>
    </div>
  </section>
</Layout>