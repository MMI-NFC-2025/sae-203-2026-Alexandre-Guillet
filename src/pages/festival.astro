---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Titre de la page -->
  <section class="bg-noir text-ivoir text-center py-16 px-4">
    <p class="text-orprofond mb-2">Le Festival</p>
    <h1 class="text-4xl font-bold">27 ans de passion pour la musique classique</h1>
  </section>

  <!-- Notre Histoire -->
  <section class="py-12 px-4 max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold mb-6">Notre Histoire</h2>
    
    <p class="mb-4">Fonde en 1998, le Festival Chorus Symphonia est ne de la volonte de creer un evenement culturel d'envergure internationale a Paris, celebrant le patrimoine musical classique tout en offrant une scene aux talents contemporains.</p>
    
    <p class="mb-4">Au fil des annees, le festival s'est impose comme un rendez-vous incontournable pour les amateurs de musique classique. Chaque edition rassemble plus de 15 000 spectateurs venus du monde entier.</p>
    
    <p class="mb-8">Grace a la qualite de sa programmation et a l'excellence de son organisation, Chorus Symphonia a accueilli les plus grands orchestres et solistes internationaux.</p>

    <!-- Statistiques -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      <div class="bg-doreclair p-6 rounded text-center">
        <p class="text-4xl font-bold text-orprofond">27 ans</p>
        <p>d'histoire</p>
      </div>
      <div class="bg-doreclair p-6 rounded text-center">
        <p class="text-4xl font-bold text-orprofond">250+</p>
        <p>artistes accueillis</p>
      </div>
      <div class="bg-doreclair p-6 rounded text-center">
        <p class="text-4xl font-bold text-orprofond">400 000+</p>
        <p>spectateurs</p>
      </div>
    </div>
  </section>

  <!-- Nos Valeurs -->
  <section class="bg-doreclair py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-8 text-center">Nos Valeurs</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded shadow">
          <h3 class="text-xl font-bold mb-2">Excellence Artistique</h3>
          <p class="text-grisclair">Proposer une programmation de qualite exceptionnelle avec les meilleurs artistes internationaux.</p>
        </div>
        
        <div class="bg-white p-6 rounded shadow">
          <h3 class="text-xl font-bold mb-2">Accessibilite</h3>
          <p class="text-grisclair">Rendre la musique classique accessible a tous les publics, des melomanes aux neophytes.</p>
        </div>
        
        <div class="bg-white p-6 rounded shadow">
          <h3 class="text-xl font-bold mb-2">Transmission</h3>
          <p class="text-grisclair">Favoriser la decouverte et l'apprentissage de la musique classique aupres des jeunes generations.</p>
        </div>
        
        <div class="bg-white p-6 rounded shadow">
          <h3 class="text-xl font-bold mb-2">Innovation</h3>
          <p class="text-grisclair">Proposer des formats innovants tout en respectant les traditions du repertoire classique.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Notre Equipe -->
  <section class="py-12 px-4 max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold mb-8 text-center">Notre Equipe</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="bg-white p-6 rounded shadow text-center">
        <div class="bg-grisclair/30 h-32 w-32 rounded-full mx-auto mb-4 flex items-center justify-center">Photo</div>
        <h3 class="font-bold">Elisabeth Rousseau</h3>
        <p class="text-orprofond text-sm">Directrice Artistique</p>
      </div>
      
      <div class="bg-white p-6 rounded shadow text-center">
        <div class="bg-grisclair/30 h-32 w-32 rounded-full mx-auto mb-4 flex items-center justify-center">Photo</div>
        <h3 class="font-bold">Marc Fontaine</h3>
        <p class="text-orprofond text-sm">Directeur General</p>
      </div>
      
      <div class="bg-white p-6 rounded shadow text-center">
        <div class="bg-grisclair/30 h-32 w-32 rounded-full mx-auto mb-4 flex items-center justify-center">Photo</div>
        <h3 class="font-bold">Claire Dubois</h3>
        <p class="text-orprofond text-sm">Responsable Programmation</p>
      </div>
      
      <div class="bg-white p-6 rounded shadow text-center">
        <div class="bg-grisclair/30 h-32 w-32 rounded-full mx-auto mb-4 flex items-center justify-center">Photo</div>
        <h3 class="font-bold">Antoine Martin</h3>
        <p class="text-orprofond text-sm">Responsable Communication</p>
      </div>
    </div>
  </section>
</Layout>
