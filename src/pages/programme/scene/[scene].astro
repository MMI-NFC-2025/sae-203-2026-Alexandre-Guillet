---
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import PbImage from '../../../components/PbImage.astro';
import { getArtistesBySceneId, getAllScenes, getSceneById, getAllRepresentations, getAllDays } from '../../../../backend/backend.mjs';

// Route dynamique
export async function getStaticPaths() {
  const scenes = await getAllScenes();
  return scenes.map((s) => ({ params: { scene: s.id } }));
}

const { scene: sceneId } = Astro.params;

// Recuperer les donnees
const artistes = await getArtistesBySceneId(sceneId);
const scenes = await getAllScenes();
const currentScene = await getSceneById(sceneId);
const representations = await getAllRepresentations();
const jours = await getAllDays();

// Fonctions utilitaires
function formatDate(dateStr) {
  if (!dateStr) return "";
  const date = new Date(dateStr);
  return date.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long' });
}

function formatTime(dateStr) {
  if (!dateStr) return "";
  const date = new Date(dateStr);
  return date.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
}

function getSceneName(sceneId) {
  const scene = scenes.find(s => s.id === sceneId);
  return scene ? scene.nom : "Lieu a confirmer";
}
---

<Layout>
  <PageHeader 
    title={`Programme - ${currentScene?.nom || 'Scene'}`}
    subtitle={`Concerts a ${currentScene?.nom || 'cette scene'}`}
  />

  <!-- Filtres -->
  <section class="bg-doreclair py-6 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-xl font-bold mb-4">Filtrer par</h2>
      
      <div class="flex flex-wrap gap-4">
        <div>
          <p class="font-bold mb-2">Representation</p>
          <div class="flex flex-wrap gap-2">
            <a href="/programme" class="bg-white text-noir px-3 py-1 rounded text-sm hover:bg-orprofond">Tous</a>
            {representations.map((rep) => (
              <a href={`/programme/representation/${rep}`} class="bg-white text-noir px-3 py-1 rounded text-sm hover:bg-orprofond">
                {rep.charAt(0).toUpperCase() + rep.slice(1)}
              </a>
            ))}
          </div>
        </div>
        
        <div>
          <p class="font-bold mb-2">Scene</p>
          <div class="flex flex-wrap gap-2">
            {scenes.map((s) => (
              <a 
                href={`/programme/scene/${s.id}`} 
                class={`px-3 py-1 rounded text-sm ${s.id === sceneId ? 'bg-noir text-ivoir' : 'bg-white text-noir hover:bg-orprofond'}`}
              >
                {s.nom}
              </a>
            ))}
          </div>
        </div>
        
        <div>
          <p class="font-bold mb-2">Jour</p>
          <div class="flex flex-wrap gap-2">
            {jours.map((jour) => (
              <a href={`/programme/jour/${jour}`} class="bg-white text-noir px-3 py-1 rounded text-sm hover:bg-orprofond">
                {new Date(jour).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' })}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Liste -->
  <section class="py-12 px-4 max-w-4xl mx-auto">
    {artistes.length === 0 ? (
      <p class="text-center text-grisclair">Aucun concert a {currentScene?.nom || 'cette scene'}.</p>
    ) : (
      <div class="space-y-6">
        {artistes.map((artiste) => (
          <div class="bg-white p-6 rounded shadow">
            <div class="flex flex-col md:flex-row gap-6">
              <div class="md:w-1/4">
                {artiste.image ? (
                  <PbImage record={artiste} filename={artiste.image} alt={artiste.nom} class="w-full h-32 object-cover rounded" />
                ) : (
                  <div class="w-full h-32 bg-doreclair rounded flex items-center justify-center">
                    <span class="text-orprofond text-3xl">&#9835;</span>
                  </div>
                )}
              </div>
              <div class="md:w-3/4">
                <div class="flex flex-wrap gap-2 mb-2">
                  <span class="bg-orprofond text-noir px-2 py-1 rounded text-sm font-bold">{formatDate(artiste.date_de_representation)}</span>
                  {artiste.representation && (
                    <span class="bg-noir text-ivoir px-2 py-1 rounded text-sm">{artiste.representation}</span>
                  )}
                </div>
                <h2 class="text-2xl font-bold mb-1">{artiste.nom}</h2>
                <p class="text-grisclair mb-2">{getSceneName(artiste.scene)} - {formatTime(artiste.date_de_representation)}</p>
                <div class="flex gap-4 mt-4">
                  <a href={`/artistes/${artiste.id}`} class="text-orprofond hover:underline">Voir l'artiste</a>
                  <a href="#" class="bg-orprofond text-noir px-4 py-2 rounded hover:bg-doreclair">Reserver</a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </section>
</Layout>
