---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Titre de la page -->
  <section class="bg-noir text-ivoir text-center py-16 px-4">
    <h1 class="text-4xl font-bold mb-4">Artistes</h1>
    <p class="text-xl">Rencontrez les artistes exceptionnels qui feront vibrer le festival</p>
  </section>

  <!-- Liste des artistes -->
  <section class="py-12 px-4 max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      
      <!-- Artiste 1 -->
      <div class="bg-white p-6 rounded shadow">
        <div class="bg-grisclair/30 h-48 rounded mb-4 flex items-center justify-center">Photo</div>
        <h2 class="text-xl font-bold">Anne Akiko Meyers</h2>
        <p class="text-orprofond mb-2">Violoniste</p>
        <p class="text-grisclair text-sm mb-4">Consideree comme l'une des violonistes les plus captivantes de sa generation, Anne Akiko Meyers se distingue par son jeu expressif.</p>
        <a href="#" class="text-orprofond hover:underline">En savoir plus</a>
      </div>

      <!-- Artiste 2 -->
      <div class="bg-white p-6 rounded shadow">
        <div class="bg-grisclair/30 h-48 rounded mb-4 flex items-center justify-center">Photo</div>
        <h2 class="text-xl font-bold">Eldbjorg Hemsing</h2>
        <p class="text-orprofond mb-2">Violoniste</p>
        <p class="text-grisclair text-sm mb-4">Violoniste norvegienne acclamee, reconnue pour son jeu lumineux et son engagement artistique empreint de sensibilite.</p>
        <a href="#" class="text-orprofond hover:underline">En savoir plus</a>
      </div>

      <!-- Artiste 3 -->
      <div class="bg-white p-6 rounded shadow">
        <div class="bg-grisclair/30 h-48 rounded mb-4 flex items-center justify-center">Photo</div>
        <h2 class="text-xl font-bold">Thomas Ades</h2>
        <p class="text-orprofond mb-2">Compositeur & Chef d'orchestre</p>
        <p class="text-grisclair text-sm mb-4">Compositeur, chef d'orchestre et pianiste parmi les plus influents de sa generation, reconnu pour son langage musical novateur.</p>
        <a href="#" class="text-orprofond hover:underline">En savoir plus</a>
      </div>

      <!-- Artiste 4 -->
      <div class="bg-white p-6 rounded shadow">
        <div class="bg-grisclair/30 h-48 rounded mb-4 flex items-center justify-center">Photo</div>
        <h2 class="text-xl font-bold">John Adams</h2>
        <p class="text-orprofond mb-2">Chef d'orchestre</p>
        <p class="text-grisclair text-sm mb-4">Compositeur et chef d'orchestre americain majeur, figure emblematique de la musique minimaliste contemporaine.</p>
        <a href="#" class="text-orprofond hover:underline">En savoir plus</a>
      </div>

      <!-- Artiste 5 -->
      <div class="bg-white p-6 rounded shadow">
        <div class="bg-grisclair/30 h-48 rounded mb-4 flex items-center justify-center">Photo</div>
        <h2 class="text-xl font-bold">Ludovico Einaudi</h2>
        <p class="text-orprofond mb-2">Pianiste & Compositeur</p>
        <p class="text-grisclair text-sm mb-4">Compositeur et pianiste emblematique de la scene musicale contemporaine, reconnu pour son langage epure.</p>
        <a href="#" class="text-orprofond hover:underline">En savoir plus</a>
      </div>

      <!-- Artiste 6 -->
      <div class="bg-white p-6 rounded shadow">
        <div class="bg-grisclair/30 h-48 rounded mb-4 flex items-center justify-center">Photo</div>
        <h2 class="text-xl font-bold">Daniel Barenboim</h2>
        <p class="text-orprofond mb-2">Chef d'orchestre & Pianiste</p>
        <p class="text-grisclair text-sm mb-4">Pianiste et chef d'orchestre de renommee mondiale, connu pour ses interpretations profondes et son engagement humaniste.</p>
        <a href="#" class="text-orprofond hover:underline">En savoir plus</a>
      </div>

    </div>
  </section>
</Layout>
