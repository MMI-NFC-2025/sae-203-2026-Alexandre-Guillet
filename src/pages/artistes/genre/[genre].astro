---
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import ArtisteCard from '../../../components/ArtisteCard.astro';
import Button from '../../../components/Button.astro';
import { getArtistesByGenre, getAllGenres } from '../../../../backend/backend.mjs';

// Generer les pages pour chaque genre
export async function getStaticPaths() {
  let genres = [];
  try {
    genres = await getAllGenres();
  } catch (error) {
    console.error("Erreur chargement genres:", error);
  }
  
  return genres.map((genre) => ({
    params: { genre: genre },
  }));
}

const { genre } = Astro.params;

// Recuperer les artistes de ce genre
let artistes = [];
try {
  artistes = await getArtistesByGenre(genre);
} catch (error) {
  console.error("Erreur chargement artistes:", error);
}
---

<Layout>
  <PageHeader 
    title={`Genre : ${genre}`}
    subtitle={`${artistes.length} artiste(s) dans ce genre`}
  />

  <section class="py-12 px-4 max-w-6xl mx-auto">
    <div class="mb-8">
      <Button href="/artistes" variant="outline">Tous les artistes</Button>
    </div>
    
    {artistes.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {artistes.map((artiste) => (
          <ArtisteCard artiste={artiste} />
        ))}
      </div>
    ) : (
      <p class="text-center text-grisclair">Aucun artiste dans ce genre.</p>
    )}
  </section>
</Layout>
