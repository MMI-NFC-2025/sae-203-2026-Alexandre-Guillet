---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import ArtisteCard from '../../components/ArtisteCard.astro';
import { getAllArtistes } from '../../../backend/backend.mjs';

// Recuperer tous les artistes depuis PocketBase
let artistes = [];
try {
  artistes = await getAllArtistes();
} catch (error) {
  console.error("Erreur chargement artistes:", error);
}
---

<Layout>
  <PageHeader 
    title="Artistes" 
    subtitle="Rencontrez les artistes exceptionnels qui feront vibrer le festival" 
  />

  <section class="py-12 px-4 max-w-6xl mx-auto">
    {artistes.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {artistes.map((artiste) => (
          <ArtisteCard artiste={artiste} />
        ))}
      </div>
    ) : (
      <p class="text-center text-grisclair">Aucun artiste trouve. Verifiez la connexion PocketBase.</p>
    )}
  </section>
</Layout>
