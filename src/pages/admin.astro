---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { isUserAuthenticated, getCurrentUser } from '../../backend/backend.mjs';
<Layout>
  <PageHeader 
    title="Administration" 
    subtitle="Gérer les artistes et scènes"
  />

  <section class="py-12 px-4 max-w-4xl mx-auto">
    {getCurrentUser() && (
      <p class="mb-8 text-center text-grisclair">Connecté en tant que: {getCurrentUser()?.email}</p>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <div class="bg-white p-8 rounded shadow">
        <h2 class="text-2xl font-bold mb-6">Ajouter un artiste</h2>
        <form action="/api/add-artiste" method="POST" class="space-y-4">
          <div>
            <label for="nom" class="block font-bold mb-2">Nom</label>
            <input type="text" id="nom" name="nom" required class="w-full border rounded px-3 py-2" />
          </div>
          
          <div>
            <label for="specialite" class="block font-bold mb-2">Spécialité</label>
            <input type="text" id="specialite" name="specialite" placeholder="ex: Violoniste" class="w-full border rounded px-3 py-2" />
          </div>
          <div>
            <label for="description" class="block font-bold mb-2">Description</label>
            <textarea id="description" name="description" rows="4" class="w-full border rounded px-3 py-2"></textarea>
          </div>
          
          <div>
            <label for="scene" class="block font-bold mb-2">Scène (ID)</label>
            <input type="text" id="scene" name="scene" placeholder="ID de la scène" class="w-full border rounded px-3 py-2" />
          </div>
          
          <div>
            <label for="date_de_representation" class="block font-bold mb-2">Date de représentation</label>
            <input type="datetime-local" id="date_de_representation" name="date_de_representation" class="w-full border rounded px-3 py-2" />
          </div>
          
          <button type="submit" class="w-full bg-orprofond text-noir px-4 py-2 rounded font-bold hover:bg-doreclair">
            Ajouter
          </button>
        </form>
      </div>
      <div class="bg-white p-8 rounded shadow">
        <h2 class="text-2xl font-bold mb-6">Ajouter une scène</h2>
        <form action="/api/add-scene" method="POST" class="space-y-4">
          <div>
            <label for="scene-nom" class="block font-bold mb-2">Nom</label>
            <input type="text" id="scene-nom" name="nom" required class="w-full border rounded px-3 py-2" />
          </div>
          
          <div>
            <label for="scene-description" class="block font-bold mb-2">Description</label>
            <textarea id="scene-description" name="description" rows="4" class="w-full border rounded px-3 py-2"></textarea>
          </div>
          
          <div>
            <label for="scene-localisation" class="block font-bold mb-2">Localisation</label>
            <input type="text" id="scene-localisation" name="localisation" class="w-full border rounded px-3 py-2" />
          </div>
          
          <div>
            <label for="scene-capacite" class="block font-bold mb-2">Capacité</label>
            <input type="number" id="scene-capacite" name="capacite" class="w-full border rounded px-3 py-2" />
          </div>
          
          <button type="submit" class="w-full bg-orprofond text-noir px-4 py-2 rounded font-bold hover:bg-doreclair">
            Ajouter
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
