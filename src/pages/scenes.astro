---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Titre de la page -->
  <section class="bg-noir text-ivoir text-center py-16 px-4">
    <h1 class="text-4xl font-bold mb-4">Nos Scenes</h1>
    <p class="text-xl">Trois salles prestigieuses au coeur de Paris</p>
  </section>

  <!-- Liste des scenes -->
  <section class="py-12 px-4 max-w-4xl mx-auto">
    
    <!-- Scene 1 -->
    <div class="bg-white p-6 rounded shadow mb-8">
      <div class="bg-grisclair/30 h-48 rounded mb-4 flex items-center justify-center">Photo</div>
      <h2 class="text-2xl font-bold mb-2">Opera National de Paris - Grande Salle</h2>
      <p class="text-grisclair mb-2">Place de l'Opera, 75009 Paris</p>
      <p class="text-orprofond font-bold mb-4">2200 places</p>
      <p class="mb-4">La salle principale de l'Opera National de Paris, connue mondialement pour son acoustique exceptionnelle et son architecture majestueuse.</p>
      <p class="text-sm text-grisclair mb-4">Acces : Metro Opera (lignes 3, 7, 8), RER A Auber</p>
      <a href="#" class="text-orprofond hover:underline">En savoir plus</a>
    </div>

    <!-- Scene 2 -->
    <div class="bg-white p-6 rounded shadow mb-8">
      <div class="bg-grisclair/30 h-48 rounded mb-4 flex items-center justify-center">Photo</div>
      <h2 class="text-2xl font-bold mb-2">Salle Garnier</h2>
      <p class="text-grisclair mb-2">15 Avenue Montaigne, 75008 Paris</p>
      <p class="text-orprofond font-bold mb-4">600 places</p>
      <p class="mb-4">Une salle intimiste parfaite pour les recitals et la musique de chambre.</p>
      <p class="text-sm text-grisclair mb-4">Acces : Metro Alma-Marceau (ligne 9), RER C Pont de l'Alma</p>
      <a href="#" class="text-orprofond hover:underline">En savoir plus</a>
    </div>

    <!-- Scene 3 -->
    <div class="bg-white p-6 rounded shadow mb-8">
      <div class="bg-grisclair/30 h-48 rounded mb-4 flex items-center justify-center">Photo</div>
      <h2 class="text-2xl font-bold mb-2">Salon des Glaces</h2>
      <p class="text-grisclair mb-2">252 Rue du Faubourg Saint-Honore, 75008 Paris</p>
      <p class="text-orprofond font-bold mb-4">150 places</p>
      <p class="mb-4">Un lieu d'exception pour des concerts intimistes dans un cadre historique remarquable.</p>
      <p class="text-sm text-grisclair mb-4">Acces : Metro Ternes (ligne 2), Charles de Gaulle-Etoile (lignes 1, 2, 6, RER A)</p>
      <a href="#" class="text-orprofond hover:underline">En savoir plus</a>
    </div>

  </section>
</Layout>
