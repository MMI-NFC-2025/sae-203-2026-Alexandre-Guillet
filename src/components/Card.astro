---
interface Props {
  title: string;
  link?: string;
  class?: string;
}

const { title, link, class: className = "" } = Astro.props;
---

<div class={`bg-white p-6 rounded shadow ${className}`}>
  <h3 class="text-xl font-bold mb-2">{title}</h3>
  <slot />
  {link && (
    <a href={link} class="text-orprofond hover:underline mt-4 inline-block">
      En savoir plus
    </a>
  )}
</div>
